<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AITrans.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="AITrans.Views.MarkdownView"
             x:DataType="vm:MarkdownViewModel">

  <DockPanel Margin="10">
    <!-- Top Controls -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
      <Button x:Name="OpenFileBtn" Content="📂 Open MD" Click="OnOpenFileClick" />
      <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" Width="150" />
      <Button Content="▶ Translate All" Command="{Binding TranslateCommand}" />
      <Button Content="▶ Selected" Command="{Binding TranslateSelectedCommand}" ToolTip.Tip="Translate only selected rows" />
      <Button Content="▶ From Here" Command="{Binding TranslateFromSelectedCommand}" ToolTip.Tip="Translate from selected row to end" />
      <Button Content="⏹ Cancel" Command="{Binding CancelTranslationCommand}" IsVisible="{Binding IsTranslating}" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <Button Content="🔊 Read Original" Command="{Binding ReadOriginalCommand}" IsEnabled="{Binding !IsSpeaking}" ToolTip.Tip="Read original text from selected row (or from start)" />
      <Button Content="🔊 Read Translation" Command="{Binding ReadTranslationCommand}" IsEnabled="{Binding !IsSpeaking}" ToolTip.Tip="Read translation from selected row (or from start)" />
      <Button Content="⏸ Stop" Command="{Binding StopSpeechCommand}" IsVisible="{Binding IsSpeaking}" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <Button Content="🗄 Cache" Command="{Binding SaveCacheCommand}" ToolTip.Tip="Save current translation session to database" />
      <Button Content="♫ Restore" x:Name="RestoreBtn" Click="OnRestoreCacheClick" IsEnabled="{Binding HasCache}" ToolTip.Tip="Izberi kesh sesiq za vръщане" />
      <Button x:Name="CopyResultBtn" Content="📋 Copy" Click="OnCopyResultClick" />
      <ProgressBar IsVisible="{Binding IsTranslating}" Value="{Binding Progress}" Maximum="100" Width="200" MinHeight="20" />
    </StackPanel>

    <!-- File path indicator -->
    <TextBlock DockPanel.Dock="Top" Text="{Binding LoadedFilePath}" Margin="0,0,0,2" FontSize="12" Opacity="0.6"
               IsVisible="{Binding LoadedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <!-- Cache info -->
    <TextBlock DockPanel.Dock="Top" Text="{Binding CacheInfo}" Margin="0,0,0,5" FontSize="11" Opacity="0.8"
               IsVisible="{Binding HasCache}" />

    <!-- Status bar -->
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Margin="0,5,0,0" Opacity="0.7" TextWrapping="Wrap" />

    <!-- Two-part layout: Input on top, DataGrid below -->
    <Grid RowDefinitions="Auto,5,*">
      <!-- Input area -->
      <DockPanel Grid.Row="0" MaxHeight="200">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
          <TextBlock Text="Input (paste markdown text)" FontWeight="Bold" VerticalAlignment="Center" />
          <Button Content="📝 Parse Paragraphs" Command="{Binding ParseParagraphsCommand}" Padding="8,4" />
          <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
          <TextBlock Text="Web:" FontWeight="Bold" VerticalAlignment="Center" />
          <TextBox Text="{Binding WebUrl}" Watermark="Enter web address..." Width="300" Height="32" VerticalAlignment="Center" />
          <Button Content="🌐 Parse Web" Command="{Binding ParseFromWebCommand}" Padding="8,4" />
          <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
          <Button x:Name="SaveOriginalBtn" Content="💾 Save Original" Click="OnSaveOriginalClick"
                  Padding="8,4" ToolTip.Tip="Save the original (input) text to a file" />
          <Button x:Name="SaveTranslationBtn" Content="💾 Save Translation" Click="OnSaveFileClick"
                  Padding="8,4" ToolTip.Tip="Save the combined translation to a file" />
        </StackPanel>
        <TextBox Text="{Binding InputText}" AcceptsReturn="True" TextWrapping="Wrap"
                 Watermark="Paste markdown text here, then click Parse Paragraphs..." Height="120" />
      </DockPanel>

      <GridSplitter Grid.Row="1" Background="Gray" />

      <!-- Paragraphs DataGrid -->
      <DataGrid x:Name="ParagraphGrid" Grid.Row="2"
                x:CompileBindings="False"
                ItemsSource="{Binding Paragraphs}"
                AutoGenerateColumns="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True"
                GridLinesVisibility="Horizontal"
                SelectionMode="Extended"
                IsReadOnly="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" IsReadOnly="True" />
          <DataGridTemplateColumn Header="Original" Width="*" MinWidth="120" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBox Text="{Binding DisplayOriginalText}" TextWrapping="Wrap" Padding="4"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         IsHitTestVisible="False" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Translation" Width="*" MinWidth="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBox Text="{Binding DisplayTranslatedText}" TextWrapping="Wrap" Padding="4"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         IsHitTestVisible="False" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
            <DataGridTemplateColumn.CellEditingTemplate>
              <DataTemplate>
                <TextBox Text="{Binding TranslatedText}" TextWrapping="Wrap" AcceptsReturn="True" />
              </DataTemplate>
            </DataGridTemplateColumn.CellEditingTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </DockPanel>
</UserControl>
