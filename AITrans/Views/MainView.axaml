<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AITrans.ViewModels"
             xmlns:views="using:AITrans.Views"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AITrans.Views.MainView"
             x:DataType="vm:MainViewModel">

  <TabControl Margin="5">
    <TabItem Header="Subtitles">
      <views:SubtitlesView DataContext="{Binding SubtitlesTab}" />
    </TabItem>
    <TabItem Header="Markdown">
      <views:MarkdownView DataContext="{Binding MarkdownTab}" />
    </TabItem>
    <TabItem Header="Settings">
      <views:SettingsView DataContext="{Binding SettingsTab}" />
    </TabItem>
  </TabControl>
</UserControl>
