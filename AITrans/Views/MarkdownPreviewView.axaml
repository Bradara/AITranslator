<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AITrans.ViewModels"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="AITrans.Views.MarkdownPreviewView"
             x:DataType="vm:MarkdownPreviewViewModel">

  <DockPanel Margin="10">

    <!-- ── Toolbar ─────────────────────────────────────── -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button x:Name="OpenFileBtn" Content="📂 Open MD" Click="OnOpenFileClick" />
      <ComboBox Width="320"
                ItemsSource="{Binding RecentFiles}"
                SelectedItem="{Binding SelectedRecentFile}"
                ToolTip.Tip="Последни 5 отворени файла" />
      <Button Content="Open Recent"
              Command="{Binding OpenSelectedRecentFileCommand}"
              ToolTip.Tip="Отвори избрания файл от списъка с последни файлове" />
      <Button Content="← Back"
              Command="{Binding GoBackCommand}"
              ToolTip.Tip="Navigate back to the previous document" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <Button Content="A-" FontSize="14" FontWeight="Bold"
              Command="{Binding DecreaseFontSizeCommand}"
              ToolTip.Tip="Намали размера на шрифта в прегледа" />
      <TextBlock Text="{Binding PreviewFontSize, StringFormat={}{0}pt}"
                 VerticalAlignment="Center" MinWidth="32" TextAlignment="Center" />
      <Button Content="A+" FontSize="14" FontWeight="Bold"
              Command="{Binding IncreaseFontSizeCommand}"
              ToolTip.Tip="Увеличи размера на шрифта в прегледа" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <ComboBox ItemsSource="{Binding AvailableLanguages}"
                SelectedItem="{Binding ReadLanguage}"
                Width="130"
                ToolTip.Tip="Language for text-to-speech" />
      <Button Content="🔊 Read All"
              Command="{Binding ReadAllCommand}"
              IsEnabled="{Binding !IsSpeaking}"
              ToolTip.Tip="Read the entire document aloud from the beginning" />
      <Button Content="🔊 From Selection"
              Command="{Binding ReadFromSelectionCommand}"
              IsEnabled="{Binding !IsSpeaking}"
              ToolTip.Tip="Position cursor in the editor on the left, then click to read aloud from that point" />
      <Button Content="⏸ Stop"
              Command="{Binding StopSpeechCommand}"
              IsVisible="{Binding IsSpeaking}" />
    </StackPanel>

    <!-- ── File path ───────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding LoadedFilePath}"
               Margin="0,0,0,3" FontSize="12" Opacity="0.6"
               IsVisible="{Binding LoadedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <!-- ── Status bar ──────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Bottom"
               Text="{Binding StatusText}"
               Margin="0,5,0,0" Opacity="0.7"
               TextWrapping="Wrap" />

    <!-- ── Main split layout ───────────────────────────── -->
    <Grid ColumnDefinitions="9* , 4, 11*">

      <!-- Left: raw markdown editor -->
      <DockPanel Grid.Column="0">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4" LastChildFill="False">
          <TextBlock DockPanel.Dock="Left" Text="📝 Editor"
                     FontWeight="SemiBold" VerticalAlignment="Center" />
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
            <TextBlock Text="● unsaved"
                       Foreground="Orange" FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasUnsavedChanges}" />
            <Button Content="💾 Save" Click="OnSaveClick"
                    ToolTip.Tip="Save to current file; opens Save As dialog if no file is loaded" />
          </StackPanel>
        </DockPanel>
        <TextBox x:Name="RawEditor"
                 Text="{Binding MarkdownText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas,Menlo,monospace"
                 FontSize="13"
                 UndoLimit="200" />
      </DockPanel>

      <GridSplitter Grid.Column="1" Background="Gray" ResizeDirection="Columns"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

      <!-- Right: formatted preview -->
      <md:MarkdownScrollViewer Grid.Column="2"
                               x:Name="MarkViewer"
                               x:CompileBindings="False"
                               Margin="8,0,8,0"
                               Markdown="{Binding MarkdownText}" />

    </Grid>
  </DockPanel>
</UserControl>
