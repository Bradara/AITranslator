<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AITrans.ViewModels"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="AITrans.Views.MarkdownPreviewView"
             x:DataType="vm:MarkdownPreviewViewModel">

  <DockPanel Margin="10">

    <!-- ── Toolbar ─────────────────────────────────────── -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button x:Name="OpenFileBtn" Content="📂 Open MD" Click="OnOpenFileClick" />
      <Button x:Name="HistoryBtn" Content="📋 История" Click="OnHistoryClick"
              ToolTip.Tip="История на отворени файлове" />
      <Button Content="📘 EPUB" Click="OnExportEpubClick"
              IsEnabled="{Binding !IsExporting}"
              ToolTip.Tip="Експорт към EPUB (офлайн изображения)" />
      <Button Content="← Back"
              Command="{Binding GoBackCommand}"
              ToolTip.Tip="Navigate back to the previous document" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <Button Content="A-" FontSize="14" FontWeight="Bold"
              Command="{Binding DecreaseFontSizeCommand}"
              ToolTip.Tip="Намали размера на шрифта в прегледа" />
      <TextBlock Text="{Binding PreviewFontSize, StringFormat={}{0}pt}"
                 VerticalAlignment="Center" MinWidth="32" TextAlignment="Center" />
      <Button Content="A+" FontSize="14" FontWeight="Bold"
              Command="{Binding IncreaseFontSizeCommand}"
              ToolTip.Tip="Увеличи размера на шрифта в прегледа" />
      <Separator Width="1" Background="Gray" VerticalAlignment="Stretch" Margin="4,0" />
      <ComboBox ItemsSource="{Binding AvailableLanguages}"
                SelectedItem="{Binding ReadLanguage}"
                Width="130"
                ToolTip.Tip="Language for text-to-speech" />
      <Button Content="🔊 Read All"
              Command="{Binding ReadAllCommand}"
              IsEnabled="{Binding !IsSpeaking}"
              ToolTip.Tip="Read the entire document aloud from the beginning" />
      <Button Content="🔊 From Selection"
              Command="{Binding ReadFromSelectionCommand}"
              IsEnabled="{Binding !IsSpeaking}"
              ToolTip.Tip="Position cursor in the editor on the left, then click to read aloud from that point" />
      <Button Content="⏸ Pause"
              Command="{Binding PauseSpeechCommand}"
              IsVisible="{Binding IsSpeaking}"
              IsEnabled="{Binding !IsSpeechPaused}" />
      <Button Content="▶ Resume"
              Command="{Binding ResumeSpeechCommand}"
              IsVisible="{Binding IsSpeechPaused}" />
      <Button Content="⏹ Stop"
              Command="{Binding StopSpeechCommand}"
              IsVisible="{Binding IsSpeaking}" />
    </StackPanel>

    <!-- ── File path ───────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding LoadedFilePath}"
               Margin="0,0,0,3" FontSize="12" Opacity="0.6"
               IsVisible="{Binding LoadedFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <!-- ── Status bar ──────────────────────────────────── -->
    <TextBlock DockPanel.Dock="Bottom"
               Text="{Binding StatusText}"
               Margin="0,5,0,0" Opacity="0.7"
               TextWrapping="Wrap" />

    <!-- ── Main split layout ───────────────────────────── -->
    <Grid ColumnDefinitions="6*, 4, 4*">

      <!-- ════════════════════════════════════════════════
           LEFT PANEL — Preview / Edit toggle
           ════════════════════════════════════════════════ -->
      <DockPanel Grid.Column="0">

        <!-- Header row -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4" LastChildFill="False">
          <ToggleButton DockPanel.Dock="Left"
                        IsChecked="{Binding IsEditMode}"
                        Padding="6,3"
                        ToolTip.Tip="Превключи между форматиран изглед и редактор на маркдаун">
            <Panel>
              <TextBlock Text="👁 Preview" IsVisible="{Binding !IsEditMode}" />
              <TextBlock Text="✏ Editor" IsVisible="{Binding IsEditMode}" />
            </Panel>
          </ToggleButton>

          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
            <TextBlock Text="● unsaved"
                       Foreground="Orange" FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasUnsavedChanges}" />
            <Button Content="💾 Save" Click="OnSaveClick"
                    ToolTip.Tip="Save to current file; opens Save As dialog if no file is loaded" />
          </StackPanel>
        </DockPanel>

        <!-- ── Formatted Preview (default) ── -->
        <md:MarkdownScrollViewer x:Name="MarkViewer"
                                 x:CompileBindings="False"
                                 Margin="0,0,4,0"
                                 Markdown="{Binding MarkdownText}"
                                 SelectionEnabled="True"
                                 IsVisible="{Binding !IsEditMode}" />

        <!-- ── Raw Markdown Editor (edit mode) ── -->
        <TextBox x:Name="RawEditor"
                 Text="{Binding MarkdownText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas,Menlo,monospace"
                 FontSize="13"
                 UndoLimit="200"
                 IsVisible="{Binding IsEditMode}" />

      </DockPanel>

      <GridSplitter Grid.Column="1" Background="Gray" ResizeDirection="Columns"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

      <!-- ════════════════════════════════════════════════
           RIGHT PANEL — AI Chat
           ════════════════════════════════════════════════ -->
      <DockPanel Grid.Column="2" Margin="4,0,0,0">

        <!-- ── Chat header ── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4" LastChildFill="False">
          <TextBlock DockPanel.Dock="Left" Text="🤖 AI Асистент"
                     FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock DockPanel.Dock="Left" Margin="8,0,0,0"
                     Text="{Binding ChatProviderModelDisplay}"
                     FontSize="10" Opacity="0.55" VerticalAlignment="Center" />
          <Button DockPanel.Dock="Right"
                  Content="🗑 Изчисти"
                  Command="{Binding ClearChatCommand}"
                  FontSize="11"
                  ToolTip.Tip="Изтрий цялата чат история" />
        </DockPanel>

        <!-- ── Chat input + action buttons (docked to bottom) ── -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,6,0,0">
          <TextBox x:Name="ChatInputBox"
                   Text="{Binding ChatInput}"
                   Watermark="Въведи текст или задай въпрос... (Ctrl+Enter за изпращане)"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   MinHeight="70"
                   MaxHeight="150"
                   FontSize="12"
                   KeyDown="OnChatInputKeyDown" />
          <WrapPanel Orientation="Horizontal">
            <Button x:Name="PasteClipboardBtn"
                    Content="📋 Клипборд"
                    Click="OnPasteFromClipboardClick"
                    FontSize="11" Margin="0,0,4,4"
                    ToolTip.Tip="Постави текста от клипборда в полето" />
            <Button Content="✖ Изчисти"
                    Command="{Binding ClearContextCommand}"
                    FontSize="11" Margin="0,0,4,4" />
            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                      SelectedItem="{Binding ChatLanguage}"
                      FontSize="11" Margin="0,0,4,4" />
            <Button Content="🌐 Преведи"
                    Click="OnTranslateClick"
                    IsEnabled="{Binding !IsChatBusy}"
                    FontSize="11" Margin="0,0,4,4"
                    ToolTip.Tip="Преведи маркирания текст на избрания език" />
            <Button Content="💡 Обясни"
                    Click="OnExplainClick"
                    IsEnabled="{Binding !IsChatBusy}"
                    FontSize="11" Margin="0,0,4,4"
                    ToolTip.Tip="Обясни маркирания текст" />
            <Button Content="📝 Обобщи"
                    Click="OnSummarizeClick"
                    IsEnabled="{Binding !IsChatBusy}"
                    FontSize="11" Margin="0,0,4,4"
                    ToolTip.Tip="Направи обобщение на маркирания текст" />
            <Button Content="↵ Изпрати"
                    Command="{Binding SendChatCommand}"
                    IsEnabled="{Binding !IsChatBusy}"
                    FontSize="11" Margin="0,0,0,4"
                    ToolTip.Tip="Изпрати съобщение (Ctrl+Enter)" />
          </WrapPanel>
        </StackPanel>

        <!-- ── Busy indicator ── -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="⏳ AI мисли..."
                   IsVisible="{Binding IsChatBusy}"
                   FontSize="11" Opacity="0.7"
                   Margin="0,2,0,2" />

        <!-- ── Chat history (fills remaining space) ── -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding ChatMessages}"
                        Margin="0,0,0,4">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Panel Margin="0,0,0,6">

                  <!-- User message — right-aligned -->
                  <Border IsVisible="{Binding IsUser}"
                          HorizontalAlignment="Right"
                          MaxWidth="320"
                          CornerRadius="10,2,10,10"
                          Background="#1E88E5"
                          Padding="10,7">
                    <SelectableTextBlock Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         FontSize="12"
                                         Foreground="White" />
                  </Border>

                  <!-- Assistant message — left-aligned -->
                  <Border IsVisible="{Binding IsAssistant}"
                          HorizontalAlignment="Left"
                          MaxWidth="320"
                          CornerRadius="2,10,10,10"
                          Padding="10,7">
                    <Border.Background>
                      <SolidColorBrush Color="#33808080" />
                    </Border.Background>
                    <SelectableTextBlock Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         FontSize="12" />
                  </Border>

                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

      </DockPanel>

    </Grid>
  </DockPanel>
</UserControl>

