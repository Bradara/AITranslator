<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AITrans.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AITrans.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Grid ColumnDefinitions="*,Auto,*">

    <!-- LEFT COLUMN: AI Provider Settings -->
    <ScrollViewer Grid.Column="0">
      <StackPanel Margin="16,12" Spacing="14">
        <TextBlock Text="AI Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />

        <StackPanel Spacing="5">
          <TextBlock Text="Provider" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AvailableProviders}" SelectedItem="{Binding SelectedProvider}" Width="240" />
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- OpenAI -->
        <StackPanel Spacing="10" IsVisible="{Binding IsOpenAi}">
          <TextBlock Text="OpenAI" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key" />
            <TextBox Text="{Binding OpenAiApiKey}" PasswordChar="&#x2022;" Watermark="sk-..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <ComboBox ItemsSource="{Binding OpenAiModels}" SelectedItem="{Binding OpenAiModel}" Width="240" />
          </StackPanel>
        </StackPanel>

        <!-- GitHub Copilot -->
        <StackPanel Spacing="10" IsVisible="{Binding IsGitHubCopilot}">
          <TextBlock Text="GitHub Copilot" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key / Token" />
            <TextBox Text="{Binding GitHubCopilotApiKey}" PasswordChar="&#x2022;" Watermark="ghp_..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ComboBox ItemsSource="{Binding GitHubCopilotModels}" SelectedItem="{Binding GitHubCopilotModel}" Width="210" />
              <Button Content="&#x1F5D1;" Command="{Binding RemoveGitHubModelCommand}"
                      ToolTip.Tip="Remove selected model from list" Padding="8,4" />
            </StackPanel>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Inference endpoint" />
            <ComboBox ItemsSource="{Binding GitHubEndpointLabels}"
                      SelectedItem="{Binding GitHubCopilotEndpointLabel}"
                      Width="340"
                      ToolTip.Tip="Which API endpoint to use for translation calls" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="&#x1F504; Fetch models" Command="{Binding FetchGitHubModelsCommand}"
                    IsEnabled="{Binding !IsFetchingModels}" Padding="10,5" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Add model manually" FontSize="12" Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBox Text="{Binding CustomGitHubModel}" Watermark="e.g. gemini-3-flash-preview" Width="195" />
              <Button Content="&#x2795; Add" Command="{Binding AddCustomGitHubModelCommand}" Padding="8,4" />
            </StackPanel>
            <TextBlock Text="Preview models in VS Code Chat may not be available via direct API calls."
                       FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>

        <!-- Google Gemini -->
        <StackPanel Spacing="10" IsVisible="{Binding IsGemini}">
          <TextBlock Text="Google Gemini" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key" />
            <TextBox Text="{Binding GeminiApiKey}" PasswordChar="&#x2022;" Watermark="AIza..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <ComboBox ItemsSource="{Binding GeminiModels}" SelectedItem="{Binding GeminiModel}" Width="240" />
          </StackPanel>
          <TextBlock Text="Free API key at aistudio.google.com/app/apikey" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

        <!-- DeepSeek -->
        <StackPanel Spacing="10" IsVisible="{Binding IsDeepSeek}">
          <TextBlock Text="DeepSeek" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key" />
            <TextBox Text="{Binding DeepSeekApiKey}" PasswordChar="&#x2022;" Watermark="sk-..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <ComboBox ItemsSource="{Binding DeepSeekModels}" SelectedItem="{Binding DeepSeekModel}" Width="240" />
          </StackPanel>
          <TextBlock Text="API key at platform.deepseek.com (OpenAI-compatible)." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

        <!-- xAI (Grok) -->
        <StackPanel Spacing="10" IsVisible="{Binding IsGroq}">
          <TextBlock Text="xAI" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key" />
            <TextBox Text="{Binding GroqApiKey}" PasswordChar="&#x2022;" Watermark="xai-..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ComboBox ItemsSource="{Binding GroqModels}" SelectedItem="{Binding GroqModel}" Width="210" />
              <Button Content="&#x1F5D1;" Command="{Binding RemoveGroqModelCommand}"
                      ToolTip.Tip="Remove selected model from list" Padding="8,4" />
            </StackPanel>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="&#x1F504; Fetch models" Command="{Binding FetchGroqModelsCommand}"
                    IsEnabled="{Binding !IsFetchingModels}" Padding="10,5" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Add model manually" FontSize="12" Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBox Text="{Binding CustomGroqModel}" Watermark="e.g. grok-4" Width="195" />
              <Button Content="&#x2795; Add" Command="{Binding AddCustomGroqModelCommand}" Padding="8,4" />
            </StackPanel>
            <TextBlock Text="API key at console.x.ai (OpenAI-compatible). Models: grok-4, grok-3, grok-3-fast."
                       FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>

        <!-- OpenRouter -->
        <StackPanel Spacing="10" IsVisible="{Binding IsOpenRouter}">
          <TextBlock Text="OpenRouter" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Spacing="4">
            <TextBlock Text="API Key" />
            <TextBox Text="{Binding OpenRouterApiKey}" PasswordChar="&#x2022;" Watermark="sk-or-..." />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Model" />
            <ComboBox ItemsSource="{Binding OpenRouterModels}" SelectedItem="{Binding OpenRouterModel}" Width="240" />
          </StackPanel>
          <StackPanel Spacing="4">
            <ToggleSwitch IsChecked="{Binding OpenRouterAutoRotate}"
                          OnContent="Auto-rotate free models" OffContent="Use selected model only" />
            <TextBlock Text="Cycles through free models per batch; switches on 429 errors."
                       FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="&#x1F504; Fetch free models" Command="{Binding FetchFreeModelsCommand}"
                    IsEnabled="{Binding !IsFetchingModels}" Padding="10,5" />
            <TextBlock Text="{Binding FreeModelCount}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
          </StackPanel>
        </StackPanel>

                <Separator Margin="0,4" />

        <!-- DeepL -->
        <TextBlock Text="DeepL" FontSize="16" FontWeight="SemiBold" />
        <StackPanel Spacing="4">
          <TextBlock Text="API Key" />
          <TextBox Text="{Binding DeepLApiKey}" PasswordChar="&#x2022;" Watermark="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx" />
        </StackPanel>
        <StackPanel Spacing="4">
          <ToggleSwitch IsChecked="{Binding DeepLFreeApi}"
                        OnContent="Free API (api-free.deepl.com)" OffContent="Paid API (api.deepl.com)" />
          <TextBlock Text="Free tier: 500 000 chars/month. Register at deepl.com/pro#developer"
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <ToggleSwitch IsChecked="{Binding UseDeepLForMarkdown}"
                        OnContent="Use DeepL for Markdown tab" OffContent="Use AI model for Markdown tab" />
          <TextBlock Text="When enabled, Markdown tab uses DeepL instead of the AI provider."
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

                <Separator Margin="0,4" />

        <!-- Azure AI Translator (Foundry / Cognitive Services) -->
        <TextBlock Text="Azure AI Translator" FontSize="16" FontWeight="SemiBold" />
        <StackPanel Spacing="4">
          <TextBlock Text="API Key (Ocp-Apim-Subscription-Key)" />
          <TextBox Text="{Binding AzureTranslatorApiKey}" PasswordChar="&#x2022;"
                   Watermark="Azure Translator subscription key" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Endpoint" />
          <TextBox Text="{Binding AzureTranslatorEndpoint}"
                   Watermark="https://api.cognitive.microsofttranslator.com" />
          <TextBlock Text="Default: global endpoint. For Foundry/custom endpoints use: https://&lt;name&gt;.cognitiveservices.azure.com"
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Region (optional)" />
          <TextBox Text="{Binding AzureTranslatorRegion}" Watermark="e.g. westeurope (required for global endpoint)" />
          <TextBlock Text="Required when using the global endpoint. Not needed for regional/Foundry endpoints."
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <ToggleSwitch IsChecked="{Binding UseAzureTranslatorForMarkdown}"
                        OnContent="Use Azure Translator for Markdown tab" OffContent="Use AI model for Markdown tab" />
          <TextBlock Text="When enabled, Markdown tab uses Azure AI Translator instead of the AI provider."
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <!-- Divider -->
    <GridSplitter Grid.Column="1" Width="1"
                  Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                  ResizeBehavior="PreviousAndNext" VerticalAlignment="Stretch" Margin="4,0" />

    <!-- RIGHT COLUMN: General Settings -->
    <ScrollViewer Grid.Column="2">
      <StackPanel Margin="16,12" Spacing="14">
        <TextBlock Text="General Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />

        <!-- Ebook import working folder -->
        <StackPanel Spacing="5">
          <TextBlock Text="Ebook working folder" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Text="{Binding EbookWorkingFolder}"
                     Watermark="Select a folder for imported Markdown and images"
                     Width="300" />
            <Button Content="Browse..." Click="OnPickEbookFolderClick" Padding="10,4" />
          </StackPanel>
          <TextBlock Text="Used for EPUB/FB2 import output (one markdown file + assets folder)."
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Theme -->
        <StackPanel Spacing="5">
          <TextBlock Text="Theme" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}" Width="220" />
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- Default Language -->
        <StackPanel Spacing="5">
          <TextBlock Text="Default Target Language" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding DefaultLanguage}" Width="200" />
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- Rate Limiting -->
        <TextBlock Text="Rate Limiting" FontSize="16" FontWeight="SemiBold" />
        <StackPanel Spacing="4">
          <TextBlock Text="Subtitle lines per batch" />
          <NumericUpDown Value="{Binding BatchSize}" Minimum="5" Maximum="100" Increment="5" Width="140" />
          <TextBlock Text="More lines = fewer API calls, but may hit token limits." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Markdown paragraphs per batch" />
          <NumericUpDown Value="{Binding MarkdownBatchSize}" Minimum="1" Maximum="30" Increment="1" Width="140" />
          <TextBlock Text="Default: 10. Larger = fewer calls; reduce if the model truncates output." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Delay between requests (ms)" />
          <NumericUpDown Value="{Binding DelayBetweenRequestsMs}" Minimum="0" Maximum="30000" Increment="500" Width="140" />
          <TextBlock Text="GitHub free tier: 2000-3000 ms recommended. Also applied to DeepL every 10 requests." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Temperature" />
          <NumericUpDown Value="{Binding Temperature}" Minimum="0" Maximum="2" Increment="0.1"
                         FormatString="0.0" Width="140" />
          <TextBlock Text="Copilot/OpenAI: 1.0 · DeepSeek: 1.3 · Gemini: не се прилага (използва собствен параметър)." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>



        <Separator Margin="0,4" />

        <!-- Azure Speech -->
        <TextBlock Text="Azure Speech (Text-to-Speech)" FontSize="16" FontWeight="SemiBold" />
        <StackPanel Spacing="4">
          <TextBlock Text="API Key" />
          <TextBox Text="{Binding AzureSpeechApiKey}" PasswordChar="&#x2022;" Watermark="32-char key from Azure portal" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Region" />
          <TextBox Text="{Binding AzureSpeechRegion}" Watermark="e.g. eastus, westeurope" />
          <TextBlock Text="Azure portal &#x2192; Speech resource &#x2192; Keys and Endpoint"
                     FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Original text language (Read Original)" />
          <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SpeechSourceLanguage}" Width="200" />
        </StackPanel>

        <Separator Margin="0,8" />

        <!-- Save -->
        <Button Content="&#x1F4BE; Save Settings" Command="{Binding SaveCommand}"
                HorizontalAlignment="Left" Padding="20,8" FontSize="14" />
        <TextBlock Text="{Binding StatusText}" Foreground="Green" TextWrapping="Wrap"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
