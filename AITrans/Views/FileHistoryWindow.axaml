<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:AITrans.Views"
        x:Class="AITrans.Views.FileHistoryWindow"
        x:DataType="local:FileHistoryWindow"
        x:CompileBindings="False"
        Title="История на отворени файлове"
        Width="700"
        Height="440"
        MinWidth="500"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Grid RowDefinitions="Auto,*,Auto" Margin="16,14,16,14">

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="Изберете файл за отваряне:"
               FontWeight="SemiBold"
               FontSize="15"
               Margin="0,0,0,10"/>

    <!-- File list -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding HistoryItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,3"
                    Padding="12,8"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- File info -->
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileName}"
                             FontWeight="SemiBold"
                             FontSize="14"/>
                  <TextBlock Text="{Binding FilePath}"
                             FontSize="11"
                             Opacity="0.55"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding LastOpenedText}"
                             FontSize="12"
                             Opacity="0.75"/>
                </StackPanel>

                <!-- Open button -->
                <Button Grid.Column="1"
                        Content="📂 Отвори"
                        Tag="{Binding FilePath}"
                        Click="OnOpenItem"
                        Padding="10,5"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"/>

                <!-- Delete button -->
                <Button Grid.Column="2"
                        Content="🗑"
                        Tag="{Binding FilePath}"
                        Click="OnDeleteItem"
                        ToolTip.Tip="Премахни от историята"
                        Padding="8,5"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"/>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Footer -->
    <Button Grid.Row="2"
            Content="Затвори"
            Click="OnCancel"
            HorizontalAlignment="Right"
            Margin="0,10,0,0"
            Padding="14,6"/>

  </Grid>
</Window>
